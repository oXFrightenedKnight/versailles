{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "rootDir": "../../",
    "outDir": "dist",

    "declaration": true,
    "emitDeclarationOnly": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node"],

    "paths": {
      "@repo/shared": ["../../packages/shared/src/index.ts"],
      "@repo/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"],
  "extends": "../../tsconfig.base.json"
}
